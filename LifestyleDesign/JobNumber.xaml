<Window x:Class="LifestyleDesign.JobNumber"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LifestyleDesign"
             mc:Ignorable="d" 
             d:DesignHeight="120" d:DesignWidth="375" Title="Revision Journal" MinWidth="375" MinHeight="130">
    <Border Margin="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>
            <TextBlock HorizontalAlignment="Left" Text="Enter Job Number:" VerticalAlignment="Center" Margin="0,0,0,2" ></TextBlock>
            <TextBox Grid.Row="1" Width="150" HorizontalAlignment="Left" Margin="0,5,0,0"></TextBox>
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnOK" Content="OK" Width="80" Height="25" Margin="0,0,10,0" Click="btnOK_Click"></Button>
                <Button x:Name="btnCancel" HorizontalAlignment="Right" Width="80" Height="25" Content="Cancel" Margin="0,0,10,0" Click="btnCancel_Click"></Button>
            </StackPanel>
        </Grid>
    </Border>    
</Window>
